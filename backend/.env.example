DATABASE_URL=postgresql+psycopg://xentraldesk:xentraldesk_dev@db:5432/xentraldesk

# ── PostgreSQL ──
POSTGRES_USER=xentraldesk
POSTGRES_PASSWORD=xentraldesk_dev
POSTGRES_DB=xentraldesk

# ── Redis ──
REDIS_URL=redis://redis:6379/0

# ── Auth / JWT ──
SECRET_KEY=change-me-to-a-random-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── Google Gemini AI ──
GEMINI_API_KEY=<put in your GEMINI_API_KEY>

# ── Stripe ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── S3 / MinIO (file storage) ──
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=xentraldesk

# ── App ──
ENVIRONMENT=development
DEBUG=true
BASE_URL=http://localhost:8000
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000
